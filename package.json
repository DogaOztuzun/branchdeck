{
  "name": "branchdeck",
  "version": "0.2.0",
  "description": "Terminal-first workflow manager for git repositories and worktrees",
  "type": "module",
  "workspaces": [
    "sidecar"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "check": "biome check .",
    "check:fix": "biome check --fix .",
    "test": "vitest run",
    "test:rust": "cd src-tauri && cargo test",
    "test:all": "vitest run && cd src-tauri && cargo test",
    "lint:all": "biome check . && cd src-tauri && cargo fmt --check && cargo clippy --all-targets -- -D warnings",
    "verify": "biome check . && vitest run && cd src-tauri && cargo fmt --check && cargo clippy --all-targets -- -D warnings && cargo test",
    "tauri": "tauri",
    "test:e2e": "xvfb-run bunx wdio run e2e/wdio.conf.ts"
  },
  "license": "MIT",
  "dependencies": {
    "@kobalte/core": "^0.13",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-global-shortcut": "^2",
    "@tauri-apps/plugin-log": "^2.8.0",
    "@tauri-apps/plugin-opener": "^2",
    "@xterm/addon-fit": "^0.11",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-webgl": "^0.19",
    "@xterm/xterm": "^6.0",
    "clsx": "^2.1.1",
    "lucide-solid": "^0.577.0",
    "solid-js": "^1.9.3",
    "solid-resizable-panels": "^0.5",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2",
    "@tailwindcss/vite": "^4",
    "@tauri-apps/cli": "^2",
    "@wdio/cli": "^9.26.1",
    "@wdio/local-runner": "^9.26.1",
    "@wdio/mocha-framework": "^9.26.1",
    "@wdio/spec-reporter": "^9.26.1",
    "tailwindcss": "^4",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vite-plugin-solid": "^2.11.0",
    "vitest": "^4.1.0"
  }
}
